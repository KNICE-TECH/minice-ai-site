{
  "name": "minice-ai-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"bun run dev:web\" \"bun run dev:api\"",
    "dev:web": "vite",
    "dev:api": "bun --watch server/index.ts",
    "build:wasm": "bash wasm/build.sh",
    "build:encrypt": "bun scripts/encrypt-asset.ts",
    "build:web": "tsc -b && vite build",
    "build": "bun run build:wasm && bun run build:encrypt && bun run build:web",
    "start": "NODE_ENV=production bun server/index.ts",
    "preview": "vite preview --port 4173",
    "check": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.1.0",
    "@fontsource/space-grotesk": "^5.1.0",
    "@pixiv/three-vrm": "^3.5.3",
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.0",
    "@react-three/postprocessing": "^2.16.0",
    "detect-gpu": "^5.0.0",
    "framer-motion": "^11.11.0",
    "gsap": "^3.12.5",
    "hono": "^4.12.19",
    "lenis": "^1.1.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "three": "^0.170.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
